# ── ProofBet spike configuration ──────────────────────────────────────────────
# Copy to `.env` and fill in. `.env` is gitignored.

# Solana devnet RPC (the Txoracle program ID is deployed on devnet).
RPC_URL=https://api.devnet.solana.com

# Your devnet wallet secret key. Either:
#   - a base58-encoded secret key string, OR
#   - a path to a Solana CLI keypair json file (e.g. ~/.config/solana/id.json)
WALLET_SECRET_KEY=

# TxLINE API base (no trailing slash).
#   Devnet (default): https://txline-dev.txodds.com
#   Prod/mainnet:     https://txline.txodds.com
# NOTE: the docs are inconsistent about the auth host (some examples hardcode the
# prod host, the addresses page lists the devnet host). If Phase 1 returns 401/404,
# try the other host here.
TXLINE_BASE_URL=https://txline-dev.txodds.com

# Optional: separate host for auth (guest/start, token/activate). Defaults to
# TXLINE_BASE_URL. The OpenAPI description hints auth may live on oracle/oracle-dev
# (e.g. https://oracle-dev.txodds.com) — set this only if Phase 1 fails on the host above.
TXLINE_AUTH_BASE_URL=

# Free World Cup tier service level. Devnet free tier is 1 (60s delay).
# (Level 12 real-time is mainnet-only per the docs.)
SERVICE_LEVEL_ID=1

# Subscription duration in weeks — must be a multiple of 4 (minimum 4).
DURATION_WEEKS=4

# ── Phase 3 overrides (optional) ──────────────────────────────────────────────
# If FIXTURE_ID is set, the validate phase uses these exact values instead of
# auto-discovering a fixture. Leave blank to let discovery pick a live/finished
# World Cup fixture (falls back to the docs example if none is rooted yet).
FIXTURE_ID=
SEQ=
STAT_KEY=
# Set STAT_KEY2 to also run a two-stat predicate (combined corners = 7 + 8, op add).
STAT_KEY2=
