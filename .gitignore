# dependencies (no trailing slash → also ignores node_modules symlinks, e.g. in worktrees)
node_modules
**/node_modules

# env / secrets
.env
*.env
!*.env.example
.spike-auth.json
**/id.json
**/keypair.json
**/wallet*.json

# build output
dist/
build/
*.tsbuildinfo

# logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# os / editor
.DS_Store
.idea/
.vscode/

# anchor / rust
target/
.anchor/
test-ledger/
**/*.rs.bk

# git worktrees (isolated workspaces)
.worktrees/

# TxLINE auth token cache
.txline-auth.json
**/.txline-auth.json
